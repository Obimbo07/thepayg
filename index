<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NairoBytes — Device Financing Infrastructure for Africa</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --green: #1D9E75;
    --green-dark: #0F6E56;
    --green-deep: #085041;
    --green-light: #E1F5EE;
    --green-mid: #9FE1CB;
    --ink: #0A0F0D;
    --ink-soft: #1A2420;
    --white: #FFFFFF;
    --off-white: #F7FAF9;
    --muted: #6B7C77;
    --border: rgba(29,158,117,0.15);
    --border-light: rgba(255,255,255,0.08);
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--white);
    color: var(--ink);
    line-height: 1.6;
    overflow-x: hidden;
  }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: rgba(10,15,13,0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 0.5px solid var(--border-light);
    padding: 0 2rem;
    height: 64px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .nav-logo {
    display: flex; align-items: center; gap: 10px;
    text-decoration: none;
  }
  .nav-logo-icon {
    width: 32px; height: 32px;
    background: var(--green);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 16px;
  }
  .nav-logo-text {
    font-size: 16px; font-weight: 600;
    color: var(--white);
    letter-spacing: -0.3px;
  }
  .nav-logo-text span { color: var(--green); }
  .nav-links {
    display: flex; align-items: center; gap: 2rem;
    list-style: none;
  }
  .nav-links a {
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    font-size: 14px;
    font-weight: 400;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--white); }
  .nav-cta {
    display: flex; gap: 12px; align-items: center;
  }
  .btn-ghost {
    padding: 8px 18px;
    border: 0.5px solid rgba(255,255,255,0.2);
    border-radius: 8px;
    color: var(--white);
    font-size: 13px; font-weight: 500;
    text-decoration: none;
    transition: background 0.2s;
    font-family: inherit;
    cursor: pointer;
    background: transparent;
  }
  .btn-ghost:hover { background: rgba(255,255,255,0.08); }
  .btn-primary {
    padding: 8px 20px;
    background: var(--green);
    border: none;
    border-radius: 8px;
    color: var(--white);
    font-size: 13px; font-weight: 500;
    text-decoration: none;
    transition: background 0.2s;
    font-family: inherit;
    cursor: pointer;
    white-space: nowrap;
  }
  .btn-primary:hover { background: var(--green-dark); }
  .hamburger {
    display: none;
    flex-direction: column; gap: 5px; cursor: pointer; padding: 4px;
  }
  .hamburger span {
    display: block; width: 22px; height: 2px;
    background: var(--white); border-radius: 2px;
    transition: transform 0.2s, opacity 0.2s;
  }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    background: var(--ink);
    display: flex; align-items: center;
    padding: 100px 2rem 80px;
    position: relative;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute; inset: 0; pointer-events: none;
  }
  .hero-glow {
    position: absolute;
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(29,158,117,0.18) 0%, transparent 70%);
    top: -100px; right: -100px;
    border-radius: 50%;
  }
  .hero-glow-2 {
    position: absolute;
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(29,158,117,0.08) 0%, transparent 70%);
    bottom: 0; left: -80px;
    border-radius: 50%;
  }
  .hero-grid-lines {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(29,158,117,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(29,158,117,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
  }
  .hero-inner {
    max-width: 1100px; margin: 0 auto; width: 100%;
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 4rem; align-items: center;
    position: relative; z-index: 1;
  }
  .hero-eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(29,158,117,0.12);
    border: 0.5px solid rgba(29,158,117,0.3);
    border-radius: 20px;
    padding: 5px 14px;
    font-size: 12px; font-weight: 500;
    color: var(--green-mid);
    margin-bottom: 1.5rem;
    letter-spacing: 0.3px;
  }
  .hero-eyebrow-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--green);
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  .hero h1 {
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -1.5px;
    color: var(--white);
    margin-bottom: 1.5rem;
  }
  .hero h1 em {
    font-style: normal;
    color: var(--green);
  }
  .hero-sub {
    font-size: 17px;
    color: rgba(255,255,255,0.55);
    line-height: 1.7;
    margin-bottom: 2.5rem;
    max-width: 460px;
    font-weight: 300;
  }
  .hero-actions {
    display: flex; gap: 12px; flex-wrap: wrap;
    margin-bottom: 3rem;
  }
  .btn-hero {
    padding: 13px 28px;
    background: var(--green);
    border: none; border-radius: 10px;
    color: var(--white);
    font-size: 15px; font-weight: 500;
    font-family: inherit; cursor: pointer;
    transition: background 0.2s, transform 0.15s;
    text-decoration: none;
    display: inline-block;
  }
  .btn-hero:hover { background: var(--green-dark); transform: translateY(-1px); }
  .btn-hero-ghost {
    padding: 13px 28px;
    background: transparent;
    border: 0.5px solid rgba(255,255,255,0.2);
    border-radius: 10px;
    color: var(--white);
    font-size: 15px; font-weight: 400;
    font-family: inherit; cursor: pointer;
    transition: background 0.2s;
    text-decoration: none;
    display: inline-block;
  }
  .btn-hero-ghost:hover { background: rgba(255,255,255,0.06); }
  .hero-trust {
    display: flex; align-items: center; gap: 16px;
    flex-wrap: wrap;
  }
  .hero-trust-label {
    font-size: 12px; color: rgba(255,255,255,0.35);
    font-weight: 400;
  }
  .hero-trust-chips {
    display: flex; gap: 8px; flex-wrap: wrap;
  }
  .trust-chip {
    padding: 4px 12px;
    background: rgba(255,255,255,0.05);
    border: 0.5px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    font-size: 11px; color: rgba(255,255,255,0.5);
  }

  /* hero phone mockup */
  .hero-visual {
    display: flex; justify-content: center; align-items: center;
    position: relative;
  }
  .phone-frame {
    width: 240px;
    background: #111;
    border-radius: 36px;
    border: 2px solid rgba(255,255,255,0.1);
    padding: 12px;
    position: relative;
    box-shadow: 0 40px 80px rgba(0,0,0,0.5);
  }
  .phone-notch {
    width: 80px; height: 8px;
    background: #000;
    border-radius: 8px;
    margin: 0 auto 10px;
  }
  .phone-screen {
    background: #0A0F0D;
    border-radius: 24px;
    padding: 1rem;
    min-height: 420px;
    overflow: hidden;
  }
  .phone-status {
    display: flex; justify-content: space-between;
    font-size: 9px; color: rgba(255,255,255,0.4);
    margin-bottom: 1rem;
  }
  .lock-screen {
    text-align: center; padding: 1rem 0;
  }
  .lock-icon {
    width: 48px; height: 48px;
    background: rgba(29,158,117,0.15);
    border: 1.5px solid var(--green);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 12px;
    font-size: 22px;
  }
  .lock-title {
    font-size: 13px; font-weight: 600; color: var(--white);
    margin-bottom: 4px;
  }
  .lock-sub {
    font-size: 10px; color: rgba(255,255,255,0.4);
    margin-bottom: 16px;
    line-height: 1.5;
  }
  .lock-amount {
    font-size: 28px; font-weight: 600;
    color: var(--green);
    margin-bottom: 4px;
  }
  .lock-due {
    font-size: 9px; color: rgba(255,255,255,0.35);
    margin-bottom: 16px;
  }
  .lock-btn {
    width: 100%; padding: 10px;
    background: var(--green);
    border: none; border-radius: 8px;
    color: var(--white);
    font-size: 11px; font-weight: 500;
    margin-bottom: 8px;
    cursor: pointer;
    font-family: inherit;
  }
  .lock-btn-ghost {
    width: 100%; padding: 10px;
    background: transparent;
    border: 0.5px solid rgba(255,255,255,0.15);
    border-radius: 8px;
    color: rgba(255,255,255,0.5);
    font-size: 11px;
    cursor: pointer;
    font-family: inherit;
  }
  .phone-divider {
    height: 0.5px; background: rgba(255,255,255,0.06);
    margin: 12px 0;
  }
  .activity-row {
    display: flex; align-items: center; gap: 8px;
    padding: 6px 0;
  }
  .activity-dot {
    width: 6px; height: 6px; border-radius: 50%;
    flex-shrink: 0;
  }
  .activity-text { font-size: 9px; color: rgba(255,255,255,0.35); flex: 1; }
  .activity-time { font-size: 9px; color: rgba(255,255,255,0.2); }
  .phone-badge {
    position: absolute;
    right: -20px; top: 60px;
    background: var(--green);
    color: var(--white);
    font-size: 10px; font-weight: 500;
    padding: 6px 12px;
    border-radius: 20px;
    white-space: nowrap;
    box-shadow: 0 4px 16px rgba(29,158,117,0.4);
  }
  .phone-badge-2 {
    position: absolute;
    left: -30px; bottom: 80px;
    background: var(--ink-soft);
    border: 0.5px solid rgba(29,158,117,0.3);
    color: rgba(255,255,255,0.7);
    font-size: 10px;
    padding: 8px 12px;
    border-radius: 10px;
    white-space: nowrap;
    box-shadow: 0 4px 16px rgba(0,0,0,0.3);
  }

  /* ── STATS TICKER ── */
  .stats-bar {
    background: var(--ink-soft);
    border-top: 0.5px solid rgba(29,158,117,0.15);
    border-bottom: 0.5px solid rgba(29,158,117,0.15);
    padding: 1.5rem 2rem;
  }
  .stats-inner {
    max-width: 1100px; margin: 0 auto;
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  .stat-item {
    text-align: center;
    padding: 0.5rem;
    border-right: 0.5px solid rgba(255,255,255,0.06);
  }
  .stat-item:last-child { border-right: none; }
  .stat-num {
    font-size: 28px; font-weight: 600;
    color: var(--green);
    letter-spacing: -1px;
    line-height: 1;
    margin-bottom: 4px;
  }
  .stat-label {
    font-size: 12px; color: rgba(255,255,255,0.4);
    font-weight: 300;
  }

  /* ── SECTIONS ── */
  section { padding: 5rem 2rem; }
  .section-inner { max-width: 1100px; margin: 0 auto; }
  .section-eyebrow {
    font-size: 11px; font-weight: 500;
    text-transform: uppercase; letter-spacing: 2px;
    color: var(--green);
    margin-bottom: 1rem;
  }
  .section-title {
    font-size: clamp(26px, 3vw, 40px);
    font-weight: 600;
    letter-spacing: -1px;
    line-height: 1.15;
    color: var(--ink);
    margin-bottom: 1rem;
  }
  .section-sub {
    font-size: 16px; color: var(--muted);
    line-height: 1.7; font-weight: 300;
    max-width: 560px;
  }

  /* ── PRODUCTS ── */
  .products { background: var(--off-white); }
  .products-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem; margin-top: 3rem;
  }
  .product-card {
    background: var(--white);
    border: 0.5px solid #E8EDE9;
    border-radius: 16px;
    padding: 2rem;
    transition: box-shadow 0.2s, transform 0.2s;
    position: relative;
    overflow: hidden;
  }
  .product-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--green);
    transform: scaleX(0);
    transition: transform 0.2s;
    transform-origin: left;
  }
  .product-card:hover { box-shadow: 0 8px 32px rgba(0,0,0,0.08); transform: translateY(-2px); }
  .product-card:hover::before { transform: scaleX(1); }
  .product-card.featured {
    border-color: var(--green);
    background: linear-gradient(135deg, #F0FBF7, var(--white));
  }
  .product-card.featured::before { transform: scaleX(1); }
  .product-icon {
    width: 44px; height: 44px;
    background: var(--green-light);
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px; margin-bottom: 1.25rem;
  }
  .product-tag {
    position: absolute; top: 1.25rem; right: 1.25rem;
    font-size: 10px; font-weight: 500;
    padding: 3px 10px; border-radius: 20px;
    background: var(--green-light);
    color: var(--green-deep);
  }
  .product-name {
    font-size: 18px; font-weight: 600;
    color: var(--ink); margin-bottom: 8px;
    letter-spacing: -0.3px;
  }
  .product-desc {
    font-size: 14px; color: var(--muted);
    line-height: 1.65; margin-bottom: 1.5rem;
    font-weight: 300;
  }
  .product-features { list-style: none; }
  .product-features li {
    font-size: 13px; color: var(--ink);
    padding: 5px 0;
    display: flex; gap: 8px; align-items: flex-start;
    border-bottom: 0.5px solid #F0F3F1;
  }
  .product-features li:last-child { border-bottom: none; }
  .product-features li::before {
    content: '✓';
    color: var(--green);
    font-weight: 600; font-size: 12px;
    margin-top: 1px; flex-shrink: 0;
  }

  /* ── HOW IT WORKS ── */
  .how-inner {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 5rem; align-items: center;
  }
  .steps { margin-top: 2rem; }
  .step {
    display: flex; gap: 1.25rem;
    padding: 1.25rem 0;
    border-bottom: 0.5px solid #EEF2EF;
  }
  .step:last-child { border-bottom: none; }
  .step-num {
    width: 32px; height: 32px; border-radius: 50%;
    background: var(--green-light);
    color: var(--green-deep);
    font-size: 13px; font-weight: 600;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; margin-top: 2px;
  }
  .step-title {
    font-size: 15px; font-weight: 500;
    color: var(--ink); margin-bottom: 4px;
  }
  .step-desc {
    font-size: 13px; color: var(--muted);
    line-height: 1.6; font-weight: 300;
  }
  .unlock-visual {
    background: var(--ink);
    border-radius: 20px;
    padding: 2rem;
    position: relative;
    overflow: hidden;
  }
  .unlock-visual::before {
    content: '';
    position: absolute;
    width: 300px; height: 300px;
    background: radial-gradient(circle, rgba(29,158,117,0.15) 0%, transparent 70%);
    top: -80px; right: -80px; border-radius: 50%;
  }
  .unlock-label {
    font-size: 11px; font-weight: 500;
    text-transform: uppercase; letter-spacing: 1.5px;
    color: var(--green); margin-bottom: 1.5rem;
  }
  .unlock-flow { position: relative; z-index: 1; }
  .unlock-step {
    display: flex; align-items: flex-start; gap: 12px;
    padding: 12px 0;
    border-bottom: 0.5px solid rgba(255,255,255,0.05);
  }
  .unlock-step:last-child { border-bottom: none; }
  .unlock-step-icon {
    width: 30px; height: 30px; border-radius: 8px;
    background: rgba(29,158,117,0.1);
    border: 0.5px solid rgba(29,158,117,0.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 14px; flex-shrink: 0;
  }
  .unlock-step-title {
    font-size: 12px; font-weight: 500; color: var(--white);
    margin-bottom: 2px;
  }
  .unlock-step-desc {
    font-size: 11px; color: rgba(255,255,255,0.4);
    line-height: 1.5;
  }
  .unlock-time {
    font-size: 36px; font-weight: 600;
    color: var(--green); text-align: center;
    margin-top: 1.5rem; padding-top: 1.5rem;
    border-top: 0.5px solid rgba(255,255,255,0.06);
  }
  .unlock-time-label {
    font-size: 12px; color: rgba(255,255,255,0.35);
    text-align: center; margin-top: 4px;
  }

  /* ── SECURITY ── */
  .security { background: var(--ink); }
  .security .section-title { color: var(--white); }
  .security .section-sub { color: rgba(255,255,255,0.45); }
  .security .section-eyebrow { color: var(--green-mid); }
  .security-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(255,255,255,0.04);
    border: 0.5px solid rgba(255,255,255,0.04);
    border-radius: 16px;
    overflow: hidden;
    margin-top: 3rem;
  }
  .security-item {
    padding: 2rem;
    background: var(--ink);
    transition: background 0.2s;
  }
  .security-item:hover { background: var(--ink-soft); }
  .security-item-icon {
    font-size: 24px; margin-bottom: 1rem;
  }
  .security-item-title {
    font-size: 15px; font-weight: 500;
    color: var(--white); margin-bottom: 6px;
  }
  .security-item-desc {
    font-size: 13px; color: rgba(255,255,255,0.4);
    line-height: 1.6; font-weight: 300;
  }

  /* ── WHO WE SERVE ── */
  .clients-grid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 1rem; margin-top: 3rem;
  }
  .client-card {
    border: 0.5px solid #E8EDE9;
    border-radius: 12px;
    padding: 1.5rem;
    text-align: center;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .client-card:hover {
    border-color: var(--green);
    box-shadow: 0 4px 20px rgba(29,158,117,0.08);
  }
  .client-icon { font-size: 28px; margin-bottom: 10px; }
  .client-name {
    font-size: 14px; font-weight: 500;
    color: var(--ink); margin-bottom: 6px;
  }
  .client-desc {
    font-size: 12px; color: var(--muted);
    line-height: 1.5;
  }

  /* ── TECH STACK ── */
  .tech { background: var(--off-white); }
  .tech-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 1rem; margin-top: 3rem;
  }
  .tech-item {
    background: var(--white);
    border: 0.5px solid #E8EDE9;
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    display: flex; align-items: flex-start; gap: 12px;
  }
  .tech-icon {
    width: 36px; height: 36px; border-radius: 8px;
    background: var(--green-light);
    display: flex; align-items: center; justify-content: center;
    font-size: 16px; flex-shrink: 0;
  }
  .tech-name {
    font-size: 14px; font-weight: 500;
    color: var(--ink); margin-bottom: 3px;
  }
  .tech-role {
    font-size: 12px; color: var(--muted);
    line-height: 1.5; font-weight: 300;
  }

  /* ── CTA ── */
  .cta-section {
    background: var(--ink);
    text-align: center;
  }
  .cta-section .section-title { color: var(--white); }
  .cta-section .section-sub {
    color: rgba(255,255,255,0.45);
    margin: 0 auto 2.5rem;
  }
  .cta-form {
    display: flex; gap: 10px; justify-content: center;
    flex-wrap: wrap; max-width: 480px; margin: 0 auto;
  }
  .cta-input {
    flex: 1; min-width: 220px;
    padding: 13px 18px;
    background: rgba(255,255,255,0.06);
    border: 0.5px solid rgba(255,255,255,0.15);
    border-radius: 10px;
    color: var(--white);
    font-size: 14px; font-family: inherit;
    outline: none;
    transition: border-color 0.2s;
  }
  .cta-input::placeholder { color: rgba(255,255,255,0.3); }
  .cta-input:focus { border-color: var(--green); }
  .cta-note {
    font-size: 12px; color: rgba(255,255,255,0.3);
    margin-top: 1rem;
  }
  .cta-alts {
    display: flex; justify-content: center; gap: 2rem;
    margin-top: 2.5rem; flex-wrap: wrap;
  }
  .cta-alt {
    display: flex; align-items: center; gap: 8px;
    font-size: 13px; color: rgba(255,255,255,0.5);
    text-decoration: none;
    transition: color 0.2s;
  }
  .cta-alt:hover { color: var(--white); }
  .cta-alt-icon { font-size: 16px; }

  /* ── PARTNERS ── */
  .partners {
    padding: 3rem 2rem;
